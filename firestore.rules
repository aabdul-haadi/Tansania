rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIREBASE SECURITY RULES
     * 
     * Refined for high-availability content management.
     * Allows public 'get' on missing documents to prevent bootstrap errors.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPublished(data) {
      return data == null || data.status == 'PUBLISHED' || data.isPublished == true;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      // Allow self-registration as admin for development purposes
      allow create: if isSignedIn();
      allow update, delete: if false; 
    }

    match /pages/{pageKey} {
      // Allow get if document is missing (null) or published
      allow get: if isAdmin() || resource == null || isPublished(resource.data);
      allow list: if isAdmin() || isPublished(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /blogPosts/{blogPostSlug} {
      allow get: if isAdmin() || resource == null || isPublished(resource.data);
      allow list: if isAdmin() || isPublished(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /destinations/{destinationId} {
      allow get: if isAdmin() || resource == null || isPublished(resource.data);
      allow list: if isAdmin() || isPublished(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /packages/{packageId} {
      allow get: if isAdmin() || resource == null || isPublished(resource.data);
      allow list: if isAdmin() || isPublished(resource.data);
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get, list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (resource != null && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get, list: if isPublished(resource.data) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /media/{mediaId} {
      allow read, write: if isAdmin();
    }

    match /siteSettings/global {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteKnowledgeGraphNodes/{nodeId} {
      allow read, write: if isAdmin();
    }
  }
}