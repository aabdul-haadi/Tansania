rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIREBASE SECURITY RULES DOCUMENTATION
     * 
     * Core Philosophy:
     * This ruleset implements a robust Administrative CMS and Safari Booking platform security model. 
     * It relies on a "Roles-First" approach for administrative actions and an "Ownership-First" 
     * approach for user-generated data (bookings, inquiries).
     * 
     * Data Structure:
     * - /users/{userId}: Private user profiles.
     * - /roles_admin/{userId}: High-security collection for identifying administrators.
     * - /pages, /blogPosts, /destinations, /packages: Content collections with draft/published states.
     * - /bookings, /inquiries: User-owned transactional data.
     * - /siteSettings: Global configuration.
     * 
     * Key Security Decisions:
     * 1. Admin Verification: Admin status is verified by checking the existence of a document 
     *    in the `/roles_admin` collection. This is highly performant and avoids custom claims latency.
     * 2. Public vs. Private Content: Content (Pages, Blogs, etc.) is publicly readable ONLY 
     *    if its status is 'PUBLISHED' or 'isPublished' is true. Admins bypass this to allow for 
     *    previewing draft content.
     * 3. Denormalized Ownership: Entities like 'Booking' and 'Inquiry' store 'userId' directly 
     *    on the document to allow immediate ownership checks without secondary lookups.
     * 4. Structural Segregation: Administrative metadata (Knowledge Graph, Media management) 
     *    is strictly isolated to Admin-only access.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user has administrative privileges via the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if a document's visibility state is set to public/published. */
    function isPublished(data) {
      return data.status == 'PUBLISHED' || data.isPublished == true;
    }

    /** @description Verifies ownership and existence for destructive or state-changing operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Profiles for registered users. Users can manage their own profile; admins can see all.
     * @path /users/{userId}
     * @allow (get) If user is the owner or an admin.
     * @deny (list) If user is not an admin.
     * @principle Ownership and Role-Based Access Control.
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Security-critical collection identifying administrators.
     * @path /roles_admin/{userId}
     * @principle Restricted Access - Only writable by Admin SDK.
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    /**
     * @description CMS-managed pages. Supports draft/published workflows.
     * @path /pages/{pageKey}
     * @allow (get) If status is PUBLISHED or user is ADMIN.
     * @principle Public Read with Owner-Only Writes (Admin).
     */
    match /pages/{pageKey} {
      allow get, list: if isPublished(resource.data) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Blog posts with SEO metadata. Supports draft/published workflows.
     * @path /blogPosts/{blogPostSlug}
     * @allow (list) If status is PUBLISHED or user is ADMIN.
     * @principle Public Read with Owner-Only Writes (Admin).
     */
    match /blogPosts/{blogPostSlug} {
      allow get, list: if isPublished(resource.data) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Travel destinations.
     * @path /destinations/{destinationId}
     */
    match /destinations/{destinationId} {
      allow get, list: if isPublished(resource.data) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Safari packages.
     * @path /packages/{packageId}
     */
    match /packages/{packageId} {
      allow get, list: if isPublished(resource.data) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Customer safari bookings. Highly sensitive transactional data.
     * @path /bookings/{bookingId}
     * @allow (create) If authenticated user sets themselves as the owner.
     * @deny (update) If user is not the owner or an admin.
     * @principle Ownership-based authorization with path/data consistency.
     */
    match /bookings/{bookingId} {
      allow get, list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (resource != null && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Customer inquiries.
     * @path /inquiries/{inquiryId}
     * @principle Flexible ownership; allows anonymous creation but secure admin management.
     */
    match /inquiries/{inquiryId} {
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    /**
     * @description Public reviews and testimonials.
     * @path /reviews/{reviewId}
     */
    match /reviews/{reviewId} {
      allow get, list: if isPublished(resource.data) || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Metadata for media assets.
     * @path /media/{mediaId}
     */
    match /media/{mediaId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Global site settings (WhatsApp, taglines, etc).
     * @path /siteSettings/global
     */
    match /siteSettings/global {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description AI Knowledge Graph nodes for site intelligence.
     * @path /siteKnowledgeGraphNodes/{nodeId}
     * @principle Strictly internal administrative data.
     */
    match /siteKnowledgeGraphNodes/{nodeId} {
      allow read, write: if isAdmin();
    }
  }
}