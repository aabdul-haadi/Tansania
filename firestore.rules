
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIREBASE SECURITY RULES - DEVELOPMENT MODE
     * 
     * Allows public read for all content collections.
     * Allows any authenticated user to write (for development simplicity).
     */

    match /{document=**} {
      // Public read access for everyone to see the site
      allow read: if true;
      
      // Any signed-in user can manage content during development
      allow write: if request.auth != null;
    }
  }
}
