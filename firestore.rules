rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an administrator
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Roles Admin: Only readable by the user themselves or an existing admin.
    // Writable by any authenticated user for development purposes (auto-promotion).
    match /roles_admin/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null;
    }

    // Users collection: Owners can read/write their own profiles. Admins have full access.
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Destinations and Packages: Publicly readable if published. Admins have full access.
    match /destinations/{destinationId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }
    match /packages/{packageId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // Bookings and Inquiries: Owners can read/write their own. Admins have full access.
    match /bookings/{bookingId} {
      allow read, write: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /inquiries/{inquiryId} {
      allow read, write: if (request.auth != null && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if true; // Allow public inquiries
    }

    // Reviews: Publicly readable if published. Admins have full access.
    match /reviews/{reviewId} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin() || (request.auth != null && request.resource.data.userId == request.auth.uid);
    }

    // Blog Posts and Pages: Publicly readable if published. Admins have full access.
    // NOTE: Non-admins MUST use a filter (where('status', '==', 'PUBLISHED')) to list these.
    match /blogPosts/{slug} {
      allow read: if isAdmin() || resource.data.status == 'PUBLISHED';
      allow write: if isAdmin();
    }
    match /pages/{pageKey} {
      allow read: if isAdmin() || resource.data.status == 'PUBLISHED';
      allow write: if isAdmin();
    }

    // Media and Site Settings: Generally admin-only for writing. Settings readable by public.
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site Knowledge Graph: Admin only.
    match /siteKnowledgeGraphNodes/{nodeId} {
      allow read, write: if isAdmin();
    }

    // Fallback rule for development
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
